# Server
NODE_ENV=development
PORT=3001

# Database (Prisma, path relative to prisma/)
# Postgres example (edit for your environment):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zyper?schema=public"

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
#
# Redis connection (production-friendly)
# Priority:
# 1) REDIS_URL (recommended for Saturn)
# 2) REDIS_HOST + REDIS_PORT
# When NODE_ENV=production and neither is set, Redis queues are disabled (API still starts).
REDIS_URL=

# Optional: serve a prebuilt frontend from this backend.
# In production you typically keep this false because frontend runs on a separate Saturn service.
SERVE_FRONTEND=false
FRONTEND_DIST_DIR=

# CORS
# Frontend origin that is allowed to call this backend.
# Example production: FRONTEND_URL="https://mini-zapier-platform-i15h4d.saturn.ac"
FRONTEND_URL=
# Optional: comma-separated additional origins
# CORS_ALLOWED_ORIGINS="http://localhost:3000,https://your-frontend.example.com"
CORS_ALLOWED_ORIGINS=

# Optional: Telegram bot token for workflow failure/paused notifications (if not set per-workflow)
# TELEGRAM_BOT_TOKEN=

# SMTP / Email action
# Configure either SMTP_URL OR SMTP_HOST+SMTP_PORT.
# In production do not rely on local SMTP.
# SMTP_URL="smtps://USER:PASS@smtp.example.com:465"
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
